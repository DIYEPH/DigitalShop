DATABASE_URL="postgresql://postgres:postgres@localhost:5432/digitalshop"
PORT=3000
NODE_ENV=development

# Dev/seed bot secret: its sha256 is seeded into telegram_bots.secret_hash
BOT_INTERNAL_SECRET="change-this-secret"

# AES-256-GCM key for per-shop credentials/secrets. Must match admin-backend.
SHOP_SECRET_ENCRYPTION_KEY=change-this-encryption-key

# Bot runner manager: one bot_binance_pay worker per ACTIVE telegram_bots row
BOT_RUNNER_ENABLED=true
BOT_RUNNER_POLL_MS=15000
# BOT_RUNNER_DIR=../bot_binance_pay
# Backend URL for runners, no /api suffix (default: http://localhost:$PORT)
# BOT_RUNNER_BACKEND_URL=http://localhost:3001

# Background jobs: expire overdue orders + poll Binance/BANK/CRYPTO payments
PENDING_ORDER_SYNC_ENABLED=true
PENDING_ORDER_SYNC_POLL_MS=30000
PENDING_ORDER_SYNC_BATCH_SIZE=100

# Daily login points
DAILY_LOGIN_POINTS_REWARD=5
DAILY_LOGIN_TIMEZONE=Asia/Ho_Chi_Minh

# Referral points (both sides credited on bind)
REFERRAL_REFERRER_BONUS=1
REFERRAL_REFEREE_BONUS=1

# Seed defaults (optional)
SEED_ADMIN_TELEGRAM_ID=900000001
SEED_USER_TELEGRAM_ID=900000002
