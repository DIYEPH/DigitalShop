DATABASE_URL="postgresql://postgres:postgres@localhost:5432/digitalshop"
PORT=3000
NODE_ENV=development

# Bot internal auth
BOT_INTERNAL_SECRET="change-this-secret"

# Binance Pay (order checkout 06)
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_PAY_ID=
# URL ảnh QR Binance Pay tĩnh (CDN hoặc static host) — bot gửi photo, không giữ file QR riêng
BINANCE_PAY_QR_URL=

# Bank VND checkout (07) — SePay poll + VietQR
SEPAY_API_KEY=
BANK_NAME=Vietcombank
BANK_ACCOUNT=
BANK_OWNER=
BANK_BIN=

# Job nền: expire đơn quá hạn + poll Binance/BANK/CRYPTO mỗi chu kỳ
PENDING_ORDER_SYNC_ENABLED=true
PENDING_ORDER_SYNC_POLL_MS=30000
PENDING_ORDER_SYNC_BATCH_SIZE=100

# Daily login points (14)
DAILY_LOGIN_POINTS_REWARD=5
DAILY_LOGIN_TIMEZONE=Asia/Ho_Chi_Minh

# Referral points (15) — cả hai nhận point ngay khi bind link
REFERRAL_REFERRER_BONUS=1
REFERRAL_REFEREE_BONUS=1

# Seed defaults (optional)
SEED_ADMIN_TELEGRAM_ID=900000001
SEED_USER_TELEGRAM_ID=900000002
