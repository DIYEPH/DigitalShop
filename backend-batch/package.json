{
  "name": "backend-batch",
  "version": "1.0.0",
  "description": "DigitalShop maintenance batch jobs",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean:cancelled-orders": "ts-node src/main.ts",
    "clean:cancelled-orders:dry-run": "ts-node src/main.ts --dry-run",
    "db:migrate": "cd ../database && npm run db:migrate",
    "db:status": "cd ../database && npm run db:status",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "nestjs",
    "batch",
    "cleanup"
  ],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "dotenv": "^17.4.2",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
