# Bot Configuration
BOT_TOKEN=your_telegram_bot_token
BOT_USERNAME=your_bot_username
SHOP_NAME=My Shop Bot

# Admin Configuration
ADMIN_IDS=123456789,987654321
ADMIN_USER_NAME=your_admin_username

# Binance Pay Configuration
BINANCE_API_KEY=your_binance_api_key
BINANCE_SECRET_KEY=your_binance_secret_key
BINANCE_PAY_ID=your_binance_pay_id

# Bank Transfer (SePay) Configuration
SEPAY_API_KEY=your_sepay_api_key
BANK_ACCOUNT=your_bank_account_number
BANK_NAME=Vietcombank
BANK_OWNER=NGUYEN VAN A
BANK_BIN=970436

# Referral Configuration (optional)
REFERRER_BONUS=1
REFEREE_BONUS=0.5
MIN_DEPOSIT_FOR_BONUS=5

# backend-bot auth integration (telegram-first)
BACKEND_API_BASE_URL=http://localhost:3000
BACKEND_BOT_SECRET=change-this-secret
BACKEND_REQUEST_TIMEOUT_MS=8000
# Daily login timezone: chỉ cấu hình trên backend (DAILY_LOGIN_TIMEZONE). Bot dùng claim_timezone từ GET /point/telegram/daily.
