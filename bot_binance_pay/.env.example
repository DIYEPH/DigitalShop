# bot_binance_pay — Telegram bot runner (one instance per shop).
#
# In production this file is NOT used: backend-bot's BotRunnerManager runs one
# instance per shop and injects every variable below from the database
# (telegram_bots, shops, shop_payment_credentials — managed in admin Settings).
# Use this file only to run a single instance manually for development.

# Per-shop (injected in production)
BOT_TOKEN=your_telegram_bot_token
BOT_USERNAME=your_bot_username
SHOP_NAME=My Shop Bot
# Support link for the "Contact admin" button (full URL or @username)
SUPPORT_URL=https://t.me/your_support_username
# UI hint only; the backend enforces actual payment availability
BANK_ENABLED=true

# backend-bot connection
# No /api suffix — the bot already prefixes its request paths
BACKEND_API_BASE_URL=http://localhost:3001
# sha256 of this value must match telegram_bots.secret_hash
BACKEND_BOT_SECRET=change-this-secret
BACKEND_REQUEST_TIMEOUT_MS=8000
