# Image tags pushed by GitHub Actions.
ADMIN_FRONTEND_IMAGE=ghcr.io/OWNER/REPO/admin-frontend:latest
ADMIN_BACKEND_IMAGE=ghcr.io/OWNER/REPO/admin-backend:latest
BACKEND_BOT_IMAGE=ghcr.io/OWNER/REPO/backend-bot:latest
BOT_BINANCE_PAY_IMAGE=ghcr.io/OWNER/REPO/bot-binance-pay:latest

# Host ports on the VPS.
# admin-frontend is public. Backends are bound to 127.0.0.1 by docker-compose.
ADMIN_FRONTEND_HOST_PORT=4100
ADMIN_BACKEND_HOST_PORT=3000
BACKEND_BOT_HOST_PORT=3001

# admin-frontend
ADMIN_FRONTEND_API_ORIGIN=http://admin-backend:3000

# Shared Neon PostgreSQL connection string.
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require

# admin-backend
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=3d
REFRESH_TOKEN_EXPIRES_IN=30d
CORS_ORIGIN=https://admin.example.com
BCRYPT_ROUNDS=12
ENABLE_RATE_LIMITING=true
MAX_REQUESTS_PER_MINUTE=1000
ADMIN_LOG_LEVEL=info
ADMIN_LOG_FORMAT=json
HEALTH_CHECK_TIMEOUT=5000

# backend-bot internal auth.
BOT_INTERNAL_SECRET=change-this-shared-bot-secret

# bot_binance_pay must use the same value as BOT_INTERNAL_SECRET.
BACKEND_BOT_SECRET=change-this-shared-bot-secret
BACKEND_API_BASE_URL=http://backend-bot:3001
BACKEND_REQUEST_TIMEOUT_MS=8000

# Telegram bot.
BOT_TOKEN=123456:telegram-bot-token
BOT_USERNAME=your_bot_username
SHOP_NAME=DigitalShop
ADMIN_IDS=123456789,987654321
ADMIN_USER_NAME=your_admin_username

# Binance Pay.
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_PAY_ID=
BINANCE_PAY_QR_URL=

# Bank transfer / SePay.
SEPAY_API_KEY=
BANK_ENABLED=true
BANK_NAME=Vietcombank
BANK_ACCOUNT=
BANK_OWNER=
BANK_BIN=

# backend-bot background jobs.
PENDING_ORDER_SYNC_ENABLED=true
PENDING_ORDER_SYNC_POLL_MS=30000
PENDING_ORDER_SYNC_BATCH_SIZE=100

# Points / referral.
DAILY_LOGIN_POINTS_REWARD=5
DAILY_LOGIN_TIMEZONE=Asia/Ho_Chi_Minh
REFERRAL_REFERRER_BONUS=1
REFERRAL_REFEREE_BONUS=1
REFERRER_BONUS=1
REFEREE_BONUS=0.5
MIN_DEPOSIT_FOR_BONUS=5
DEPOSIT_EXPIRES_MINUTES=15
