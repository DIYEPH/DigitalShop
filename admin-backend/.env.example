# Server Configuration
NODE_ENV=development
PORT=3000

# Database (shared with backend-bot)
DATABASE_URL=postgresql://postgres:password@localhost:5432/digitalshop

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here-min-256-bits
JWT_EXPIRES_IN=3d
REFRESH_TOKEN_EXPIRES_IN=30d

# CORS (admin-frontend)
CORS_ORIGIN=http://localhost:4100

# Security
BCRYPT_ROUNDS=12

# Khóa mã hóa credential/secret per-shop (AES-256-GCM) — PHẢI trùng với backend-bot
SHOP_SECRET_ENCRYPTION_KEY=change-this-encryption-key

# Rate Limiting
ENABLE_RATE_LIMITING=true
MAX_REQUESTS_PER_MINUTE=1000

# Logging
LOG_LEVEL=debug
LOG_FORMAT=pretty

# Optional: Redis for caching
REDIS_URL=redis://localhost:6379

# Optional: Admin notifications
ENABLE_ADMIN_NOTIFICATIONS=false
SLACK_WEBHOOK_URL=

# Health Check
HEALTH_CHECK_TIMEOUT=5000